{
  "name": "proroblix",
  "private": true,
  "version": "0.1.0",
  "description": "Social game creation platform for ProGameStore — build and play 3D experiences with friends via WebSocket Durable Objects.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/progamestore-online/roblix.git"
  },
  "homepage": "https://roblix.progamestore.online",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "pnpm --filter @proroblix/web dev",
    "build": "pnpm --filter @proroblix/web build",
    "test": "pnpm --filter @proroblix/web test",
    "preview": "pnpm --filter @proroblix/web preview",
    "deploy": "pnpm build && wrangler deploy"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260519.1",
    "wrangler": "^4.87.0"
  },
  "pnpm": {
    "overrides": {
      "brace-expansion@>=5.0.0 <5.0.6": ">=5.0.6",
      "ws@>=8.0.0 <8.20.1": ">=8.20.1"
    }
  }
}
